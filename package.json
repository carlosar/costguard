{
  "name": "costguard",
  "displayName": "CostGuard",
  "description": "Detects expensive code patterns — runaway Firebase reads, missing real-time listener cleanup, polling abuse, and React render loops — before they hit production.",
  "version": "0.3.1",
  "publisher": "soarone",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosar/costguard.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "costGuard.showRiskDetails",
        "title": "CostGuard: Show Risk Score Details"
      },
      {
        "command": "costGuard.setup",
        "title": "CostGuard: Setup"
      },
      {
        "command": "costGuard.generateReport",
        "title": "CostGuard: Generate Report"
      },
      {
        "command": "costGuard.resetSetup",
        "title": "CostGuard: Reset Setup State"
      }
    ],
    "configuration": {
      "title": "CostGuard",
      "properties": {
        "costGuard.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable CostGuard diagnostics."
        }
      }
    }
  },
  "bin": {
    "costguard": "out/cli.js"
  },
  "scripts": {
    "compile": "node esbuild.config.js",
    "typecheck": "tsc --noEmit -p ./",
    "watch": "node esbuild.config.js --watch",
    "vscode:prepublish": "node esbuild.config.js --minify",
    "package": "vsce package --allow-missing-repository",
    "vscode:publish": "vsce publish",
    "setup-hooks": "node scripts/setup-hooks.js",
    "predeploy": "node \"c:/Users/Carlos/.vscode/extensions/soarone.costguard-0.3.1/out/cli.js\" src/ --max-risk=MEDIUM",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/extension-telemetry": "^1.5.2",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "ts-morph": "^21.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8",
    "costguard": "latest"
  }
}
